# .env.example
# 请将此文件复制重命名为 .env，并填入你真实的配置信息

# ==========================================
# OPENAI 接入配置
# ==========================================
# 填入你的真实 API KEY（如果是 DeepSeek/通义千问等兼容服务，可以填入对应的 Key）
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 如果你使用的是国内代理或者其他 OpenAI 兼容的第三方服务，取消下面一行注释并填入接口地址
# OPENAI_API_BASE="https://api.openai.com/v1"

# ==========================================
# 向量数据库与存储配置
# ==========================================
# ChromaDB 本地持久化路径，确保 RAG 模块与写入模块指向同一个库
CHROMA_DB_DIR="./chroma_db"
